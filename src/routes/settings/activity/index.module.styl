.empty
    text-align center
    padding 40px 20px
    color var(--secondary-text-color)

    p
        margin-top 10px

.confirmBar
    display flex
    align-items center
    gap 8px
    font-size 13px

.list
    display grid
    gap 0

.headerRow
    display grid
    grid-template-columns 32px 1fr 2fr 120px 40px
    gap 12px
    padding 8px 12px
    font-size 12px
    font-weight 600
    color var(--secondary-text-color)
    border-bottom 1px solid var(--divider-color)

.row
    display grid
    grid-template-columns 32px 1fr 2fr 120px 40px
    gap 12px
    padding 8px 12px
    font-size 13px
    border-bottom 1px solid var(--divider-color)
    align-items center

    &:hover
        background var(--hover-background-color)

.undoneRow
    opacity 0.5

.actionIcon
    display flex
    align-items center
    justify-content center
    width 24px
    height 24px
    border-radius 4px
    font-size 14px

.title
    overflow hidden
    text-overflow ellipsis
    white-space nowrap

.typeBadge
    display inline-block
    font-size 11px
    padding 1px 6px
    border-radius 3px
    background var(--hover-background-color)
    color var(--secondary-text-color)
    margin-left 6px

.collections
    overflow hidden
    text-overflow ellipsis
    white-space nowrap
    color var(--secondary-text-color)

.arrow
    margin 0 4px
    color var(--accent-color)

.undoneBadge
    font-size 11px
    color var(--accent-color)
    margin-left 6px

.batchGroup
    border-left 3px solid var(--accent-color)
    margin-left 8px
    padding-left 4px

.batchHeader
    display flex
    align-items center
    gap 8px
    padding 8px 12px
    font-size 13px
    font-weight 500
    cursor pointer
    border-bottom 1px solid var(--divider-color)

    &:hover
        background var(--hover-background-color)

.batchToggle
    font-size 11px
    color var(--secondary-text-color)

.loadMore
    text-align center
    padding 16px
